# Foundr 环境配置模板
# 复制此文件为 .env.local 并填入实际的 API Key

# Google Gemini API Key (必需，用于脚本分析与提示词生成)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Moonshot Kimi API Key (可选，备选脚本分析引擎)
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here

# ZhipuAI GLM-5 API Key (可选，备选脚本分析引擎)
# 获取地址: https://bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# RunningHub API Key (视频生成功能)
# 获取地址: https://www.runninghub.cn/
RUNNINGHUB_API_KEY=your-runninghub-api-key-here
